{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grove.command.light",
  "title": "Per-shelf LED panel command",
  "type": "object",
  "required": ["ts", "shelf_id", "dim_pct"],
  "additionalProperties": false,
  "properties": {
    "ts":        { "type": "string", "format": "date-time" },
    "shelf_id":  { "type": "integer", "minimum": 0 },
    "dim_pct":   { "type": "number", "minimum": 0, "maximum": 100 },
    "ppfd_target": { "type": "number", "minimum": 0 }
  }
}
