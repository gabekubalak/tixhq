{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grove.vision.observation",
  "title": "Per-shelf vision inference result",
  "type": "object",
  "required": ["ts", "shelf_id", "phase_estimate", "leaf_area_cm2", "color_health", "model_version"],
  "additionalProperties": false,
  "properties": {
    "ts":             { "type": "string", "format": "date-time" },
    "shelf_id":       { "type": "integer", "minimum": 0 },
    "phase_estimate": { "type": "string", "enum": ["germination", "seedling", "veg_early", "veg_late", "flower", "harvest_ready"] },
    "leaf_area_cm2":  { "type": "number", "minimum": 0 },
    "color_health":   { "type": "number", "minimum": 0, "maximum": 1 },
    "deficiency": {
      "type": "object",
      "required": ["label", "confidence"],
      "properties": {
        "label":      { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "model_version":  { "type": "string" }
  }
}
