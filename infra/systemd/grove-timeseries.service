[Unit]
Description=GroveOS time-series store (VictoriaMetrics single-node)
PartOf=grove.target
After=grove-bus.service

[Service]
Type=simple
User=grove
ExecStart=/usr/local/bin/victoria-metrics-prod \
  -storageDataPath=/var/lib/grove/vm \
  -retentionPeriod=10y \
  -httpListenAddr=127.0.0.1:8428
Restart=always
RestartSec=2

[Install]
WantedBy=grove.target
