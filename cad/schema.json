{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grove.cad.dimensions",
  "title": "Physical dimensions of the GroveOS v1 appliance",
  "type": "object",
  "required": [
    "units", "cabinet", "door", "vents", "racks",
    "camera", "front_panel", "composter", "reservoirs",
    "slurry_tank", "clean_water_tank"
  ],
  "additionalProperties": false,
  "properties": {
    "units": { "const": "mm" },
    "cabinet": {
      "type": "object",
      "required": ["width", "depth", "height", "wall_thickness"],
      "additionalProperties": false,
      "properties": {
        "width":           { "type": "number", "minimum": 300, "maximum": 2000 },
        "depth":           { "type": "number", "minimum": 300, "maximum": 1500 },
        "height":          { "type": "number", "minimum": 600, "maximum": 2400 },
        "wall_thickness":  { "type": "number", "minimum": 6,   "maximum": 50 }
      }
    },
    "door": {
      "type": "object",
      "required": ["hinge", "window"],
      "additionalProperties": false,
      "properties": {
        "hinge":  { "enum": ["left", "right"] },
        "window": {
          "type": "object",
          "required": ["width", "height", "inset"],
          "additionalProperties": false,
          "properties": {
            "width":  { "type": "number", "minimum": 100 },
            "height": { "type": "number", "minimum": 100 },
            "inset":  { "type": "number", "minimum": 0,   "maximum": 200 }
          }
        }
      }
    },
    "vents": {
      "type": "object",
      "required": ["pattern", "count", "pitch", "slat_height"],
      "additionalProperties": false,
      "properties": {
        "pattern":     { "enum": ["louver", "grid"] },
        "count":       { "type": "integer", "minimum": 1, "maximum": 100 },
        "pitch":       { "type": "number",  "minimum": 4 },
        "slat_height": { "type": "number",  "minimum": 1 }
      }
    },
    "racks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": [
          "id", "x", "z", "shelves", "shelf_pitch",
          "shelf_lowest_y", "tray", "led_panel", "fan", "bezel_radius"
        ],
        "additionalProperties": false,
        "properties": {
          "id":             { "type": "integer", "minimum": 0 },
          "x":              { "type": "number" },
          "z":              { "type": "number" },
          "shelves":        { "type": "integer", "minimum": 4, "maximum": 8 },
          "shelf_pitch":    { "type": "number",  "minimum": 200, "maximum": 600 },
          "shelf_lowest_y": { "type": "number",  "minimum": 0 },
          "tray":           { "$ref": "#/$defs/box" },
          "led_panel": {
            "type": "object",
            "required": ["width", "depth", "thickness", "height_above_tray", "ppfd_max"],
            "additionalProperties": false,
            "properties": {
              "width":              { "type": "number", "minimum": 100 },
              "depth":              { "type": "number", "minimum": 100 },
              "thickness":          { "type": "number", "minimum": 5 },
              "height_above_tray":  { "type": "number", "minimum": 50, "maximum": 600 },
              "ppfd_max":           { "type": "number", "minimum": 50, "maximum": 1000 }
            }
          },
          "fan": {
            "type": "object",
            "required": ["diameter", "offset_z"],
            "additionalProperties": false,
            "properties": {
              "diameter": { "type": "number", "minimum": 40, "maximum": 200 },
              "offset_z": { "type": "number" }
            }
          },
          "bezel_radius":   { "type": "number", "minimum": 0 }
        }
      }
    },
    "camera": {
      "type": "object",
      "required": ["mount_xyz", "arm_length", "sensor"],
      "additionalProperties": false,
      "properties": {
        "mount_xyz":  { "$ref": "#/$defs/xyz" },
        "arm_length": { "type": "number", "minimum": 50, "maximum": 600 },
        "sensor":     { "type": "string" }
      }
    },
    "front_panel": {
      "type": "object",
      "required": ["lcd", "estop"],
      "additionalProperties": false,
      "properties": {
        "lcd": {
          "type": "object",
          "required": ["width", "height", "x", "y"],
          "additionalProperties": false,
          "properties": {
            "width":  { "type": "number", "minimum": 30 },
            "height": { "type": "number", "minimum": 10 },
            "x":      { "type": "number" },
            "y":      { "type": "number" }
          }
        },
        "estop": {
          "type": "object",
          "required": ["diameter", "x", "y"],
          "additionalProperties": false,
          "properties": {
            "diameter": { "type": "number", "minimum": 20, "maximum": 80 },
            "x":        { "type": "number" },
            "y":        { "type": "number" }
          }
        }
      }
    },
    "composter": {
      "allOf": [
        { "$ref": "#/$defs/box" },
        {
          "type": "object",
          "required": ["position"],
          "properties": { "position": { "$ref": "#/$defs/xyz" } }
        }
      ]
    },
    "reservoirs": {
      "type": "object",
      "required": ["count", "diameter", "height", "spacing", "row_origin"],
      "additionalProperties": false,
      "properties": {
        "count":       { "type": "integer", "const": 6 },
        "diameter":    { "type": "number",  "minimum": 40 },
        "height":      { "type": "number",  "minimum": 100 },
        "spacing":     { "type": "number",  "minimum": 50 },
        "row_origin":  { "$ref": "#/$defs/xyz" }
      }
    },
    "slurry_tank":      { "$ref": "#/$defs/box_with_pos" },
    "clean_water_tank": { "$ref": "#/$defs/box_with_pos" }
  },

  "$defs": {
    "xyz": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    },
    "box": {
      "type": "object",
      "required": ["width", "depth", "height"],
      "properties": {
        "width":  { "type": "number", "minimum": 1 },
        "depth":  { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 }
      }
    },
    "box_with_pos": {
      "type": "object",
      "required": ["width", "depth", "height", "position"],
      "additionalProperties": false,
      "properties": {
        "width":    { "type": "number", "minimum": 1 },
        "depth":    { "type": "number", "minimum": 1 },
        "height":   { "type": "number", "minimum": 1 },
        "position": { "$ref": "#/$defs/xyz" }
      }
    }
  }
}
